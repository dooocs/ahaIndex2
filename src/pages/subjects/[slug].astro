---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Masthead from '../../components/Masthead.astro';
import Footer from '../../components/Footer.astro';
import {
  getPublicDirectorySubjects,
  getRelatedSubjects,
  getSubjectInsights,
  getSubjectSignals,
  getSubjectSignalStatsBySubject,
} from '../../lib/data';
import type { SubjectInsight, SubjectSignalStats } from '../../lib/types';

export async function getStaticPaths() {
  const subjects = await getPublicDirectorySubjects();
  return subjects.map(subject => ({
    params: { slug: subject.slug },
    props: { subject },
  }));
}

const { subject } = Astro.props;

if (!subject) {
  return Astro.redirect('/subjects');
}

const insights = await getSubjectInsights(subject.id);
const highlights = insights.filter((insight: SubjectInsight) => insight.module_type === 'highlight');
const signals = await getSubjectSignals(subject.id, 12);
const statsMap = await getSubjectSignalStatsBySubject([subject.id]);
const relatedSubjects = await getRelatedSubjects(subject, 8);
const stats: SubjectSignalStats = statsMap.get(subject.id) || {
  subject_id: subject.id,
  signal_count_30d: subject.mention_count || 0,
  previous_signal_count_30d: 0,
  trend_pct_30d: subject.mention_count ? 100 : 0,
  latest_signal_at: subject.last_seen_at,
  sparkline: [0, 0, 0, 0, 0, 0, subject.mention_count || 0],
};

function dateLabel(value: string | null) {
  if (!value) return '';
  return value.slice(0, 10);
}

function evidenceCount(insight: SubjectInsight) {
  return Array.isArray(insight.evidence_item_ids) ? insight.evidence_item_ids.length : 0;
}

function trendLabel(value: number) {
  if (value > 0) return `▲ +${value}%`;
  if (value < 0) return `▼ ${value}%`;
  return '→ 0%';
}

function sparklinePoints(values: number[]) {
  const width = 128;
  const height = 32;
  const max = Math.max(...values, 1);
  const step = values.length > 1 ? width / (values.length - 1) : width;
  return values
    .map((value, index) => {
      const x = index * step;
      const y = height - (value / max) * (height - 4) - 2;
      return `${x.toFixed(1)},${y.toFixed(1)}`;
    })
    .join(' ');
}

function scoreLabel(score: number | null) {
  if (score === null || score === undefined) return '';
  return String(Math.round(score * 100));
}

const pageTitle = `${subject.display_name} | AmazingIndex Subject`;
const pageDesc = subject.definition || subject.description || `${subject.display_name} 的关键事件、突出点和横向对比。`;
---

<BaseLayout
  title={pageTitle}
  description={pageDesc}
  canonicalUrl={`https://www.amazingindex.com/subjects/${subject.slug}`}
  ogTitle={pageTitle}
  ogDescription={pageDesc}
  ogUrl={`https://www.amazingindex.com/subjects/${subject.slug}`}
>
  <Masthead subtitle="专题详情" />

  <main class="subject-detail-page">
    <header class="subject-detail-head">
      <a href="/subjects" class="subject-back">← 专题索引</a>
      <div class="subject-detail-kicker">{subject.type}</div>
      <h1>{subject.display_name}</h1>
      {(subject.definition || subject.description) && (
        <p>{subject.definition || subject.description}</p>
      )}
      <div class="subject-detail-signal">
        <div>
          <span>近30天</span>
          <strong>{stats.signal_count_30d}</strong>
          <span>条信号</span>
          <b class:list={[stats.trend_pct_30d >= 0 ? 'is-up' : 'is-down']}>{trendLabel(stats.trend_pct_30d)}</b>
        </div>
        <svg viewBox="0 0 128 32" aria-hidden="true">
          <polyline points={sparklinePoints(stats.sparkline)} />
        </svg>
      </div>
      <div class="subject-detail-meta">
        <span>{subject.slug}</span>
        {subject.section_slug && <span>{subject.section_slug}</span>}
        <span>{stats.signal_count_30d} signals</span>
        {subject.homepage_url && <a href={subject.homepage_url} target="_blank" rel="noreferrer">Homepage</a>}
      </div>
    </header>

    <section class="subject-module subject-signal-flow">
      <div class="subject-module-head">
        <div>
          <span>01</span>
          <h2>信号流</h2>
        </div>
        <strong>{stats.signal_count_30d}</strong>
      </div>
      {signals.length > 0 ? (
        <div class="subject-signal-list">
          {signals.slice(0, 6).map(signal => (
            <a class="subject-signal-item" href={signal.url || '#'} target={signal.url ? '_blank' : undefined} rel={signal.url ? 'noreferrer' : undefined}>
              <div>
                <h3>{signal.title}</h3>
                <p>
                  {signal.source_name || 'Unknown'}
                  <span>{dateLabel(signal.snapshot_date)}</span>
                  {scoreLabel(signal.score) && <b>评分 {scoreLabel(signal.score)}</b>}
                  {signal.external && <em>Web</em>}
                </p>
              </div>
              <span>→</span>
            </a>
          ))}
          {stats.signal_count_30d > 6 && <a class="subject-see-all" href="#signals">查看全部 {stats.signal_count_30d} 条 →</a>}
        </div>
      ) : (
        <div class="subject-module-empty">暂无信号</div>
      )}
    </section>

    <section class="subject-module">
      <div class="subject-module-head">
        <div>
          <span>02</span>
          <h2>近期要点</h2>
        </div>
        <strong>AI 生成</strong>
      </div>
      {highlights.length > 0 ? (
        <div class="subject-point-list">
          {highlights.map((item: SubjectInsight) => (
            <>
              {item.summary && <p>· {item.summary}</p>}
              {item.analysis && <p>· {item.analysis}</p>}
              {evidenceCount(item) > 0 && <span class="subject-evidence">{evidenceCount(item)} evidence</span>}
            </>
          ))}
        </div>
      ) : (
        <div class="subject-module-empty">暂无发布内容</div>
      )}
    </section>

    <section class="subject-module">
      <div class="subject-module-head">
        <div>
          <span>03</span>
          <h2>关联</h2>
        </div>
        <strong>{relatedSubjects.length}</strong>
      </div>
      {relatedSubjects.length > 0 ? (
        <div class="subject-related-list">
          {relatedSubjects.map(related => (
            <a href={`/subjects/${related.slug}`}>
              {related.display_name}
              <span>→</span>
            </a>
          ))}
        </div>
      ) : (
        <div class="subject-module-empty">暂无关联专题</div>
      )}
    </section>
  </main>

  <Footer />
</BaseLayout>
