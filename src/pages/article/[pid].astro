---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import type { ProcessedItem } from '../../lib/types';
import { getAllItems, getItemsByDate } from '../../lib/data';

export async function getStaticPaths() {
  const allItems = await getAllItems();
  const seen = new Map<string, ProcessedItem>();
  for (const item of allItems) {
    if (!item.processed_item_id) continue;
    if (!seen.has(item.processed_item_id)) {
      seen.set(item.processed_item_id, item);
    }
  }
  return Array.from(seen.values()).map(item => ({
    params: { pid: item.processed_item_id },
    props: { item },
  }));
}

const { item } = Astro.props;
const date = item.snapshot_date;

const items = await getItemsByDate(date);
const currentIndex = items.findIndex(i => i.processed_item_id === item.processed_item_id);
const prevItem = currentIndex > 0 ? items[currentIndex - 1] : null;
const nextItem = currentIndex >= 0 && currentIndex < items.length - 1 ? items[currentIndex + 1] : null;
---

<ArticleLayout
  item={item}
  date={date}
  items={items}
  prevItem={prevItem}
  nextItem={nextItem}
/>
