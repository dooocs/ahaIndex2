---
import Masthead from './Masthead.astro';
import BriefingCard from './BriefingCard.astro';
import Sidebar from './Sidebar.astro';
import Footer from './Footer.astro';
import type { ProcessedItem, DailyArchive, GlobalStats } from '../lib/types';

interface Props {
  items: ProcessedItem[];
  stats: GlobalStats;
  days: DailyArchive[];
  dailyArchive?: DailyArchive | null;
  date?: string;
  showArchiveBanner?: boolean;
  heading?: string;
  sidebarMode?: 'score' | 'intro';
}

const {
  items,
  stats,
  days,
  dailyArchive = null,
  date,
  showArchiveBanner = true,
  heading,
  sidebarMode = 'score',
} = Astro.props;

const snapshotDate = date || (items.length > 0 ? items[0].snapshot_date : undefined);
---

<Masthead items={items} />

<div class="layout">
  <main class="main-col">
    {heading && <h1 class="sr-only">{heading}</h1>}
    <div class="section-label">今日精选 · Today's Picks</div>
    <div class="article-list" id="article-list">
      {items.length > 0 ? (
        items.map((item, index) => (
          <BriefingCard item={item} index={index} date={snapshotDate} />
        ))
      ) : (
        <div class="loading-state">今日暂无更新</div>
      )}
    </div>
  </main>
  <Sidebar items={items} stats={stats} days={days} dailyArchive={dailyArchive} mode={sidebarMode} />
</div>

<Footer showArchiveBanner={showArchiveBanner} date={snapshotDate} />
