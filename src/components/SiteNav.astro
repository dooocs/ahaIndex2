---
const pathname = Astro.url.pathname;
const isSubjects = pathname.startsWith('/subjects');
const isDaily = !isSubjects;
---

<nav class="nav-bar" aria-label="站点导航">
  <div class="nav-inner">
    <div class="nav-tabs">
      <a href="/" class={`nav-tab ${isDaily ? 'active' : ''}`} data-astro-reload>日报</a>
      <a href="/subjects" class={`nav-tab ${isSubjects ? 'active' : ''}`} data-astro-reload>专题</a>
    </div>
  </div>
</nav>
