---
import BaseLayout from './BaseLayout.astro';
import Masthead from '../components/Masthead.astro';
import NavBar from '../components/NavBar.astro';
import Footer from '../components/Footer.astro';
import type { ProcessedItem } from '../lib/types';

interface Props {
  item: ProcessedItem;
  date: string;
  items: ProcessedItem[];
  categories: string[];
  prevItem?: ProcessedItem | null;
  nextItem?: ProcessedItem | null;
}

type Metric = {
  label: string;
  value: string;
};

const {
  item,
  date,
  items,
  categories,
  prevItem = null,
  nextItem = null,
} = Astro.props;

function parseRecord(value: unknown): Record<string, any> {
  if (!value) return {};
  if (typeof value === 'string') {
    try {
      return JSON.parse(value);
    } catch {
      return {};
    }
  }
  return typeof value === 'object' ? value as Record<string, any> : {};
}

function asStringArray(value: unknown): string[] {
  return Array.isArray(value)
    ? value.filter((entry): entry is string => typeof entry === 'string' && entry.trim().length > 0)
    : [];
}

function formatNumber(value: unknown): string {
  const num = Number(value);
  if (!Number.isFinite(num)) return String(value ?? '');
  if (Math.abs(num) >= 1000000) return `${(num / 1000000).toFixed(1)}m`;
  if (Math.abs(num) >= 1000) return `${(num / 1000).toFixed(1)}k`;
  return String(num);
}

function formatDate(dateValue: string): string {
  return dateValue ? dateValue.replace(/-/g, '.') : '';
}

function cleanMetricLabel(label: string): string {
  return label.replace(/^[^A-Za-z0-9\u4e00-\u9fff]+/, '').trim() || label;
}

function articleUrlFor(target: ProcessedItem | null): string {
  return target?.processed_item_id ? `/article/${target.processed_item_id}` : '#';
}

function articleTitleFor(target: ProcessedItem | null): string {
  return target?.processed_title || target?.title || '无标题';
}

const extra = parseRecord(item.extra);
const rawMetrics = parseRecord(item.raw_metrics);
const enrichment = parseRecord(extra.enrichment);
const tweets = Array.isArray(extra.tweets)
  ? extra.tweets.filter((tweet: unknown): tweet is Record<string, any> => Boolean(tweet) && typeof tweet === 'object')
  : [];

const titleText = item.processed_title || item.title || '无标题';
const summaryText = item.summary || '';
const dateText = formatDate(item.snapshot_date || date);
const rankText = String(item.rank || 0).padStart(3, '0');
const ahaScore = ((Number(item.aha_index) || 0) * 100).toFixed(1);
const articleUrl = `https://www.amazingindex.com/article/${item.processed_item_id}`;
const dailyUrl = `https://www.amazingindex.com/daily/${date}`;
const backUrl = `/daily/${date}`;
const sourceName = item.source_name || 'Unknown Source';
const originalUrl = item.original_url || item.url || '';
const contentTypeLabel = item.content_type ? `#${item.content_type.toUpperCase()}` : '#SNAPSHOT';
const metaDescription = [
  summaryText.slice(0, 150),
  sourceName ? `来源：${sourceName}` : '',
  `推荐指数 ${ahaScore}`,
].filter(Boolean).join(' · ');

const sourceMetrics: Metric[] = [];
const seenMetricKeys = new Set<string>();
function addMetric(label: string, value: unknown) {
  if (value === undefined || value === null || value === '') return;
  const cleanLabel = cleanMetricLabel(label);
  const key = cleanLabel.toLowerCase();
  if (seenMetricKeys.has(key)) return;
  seenMetricKeys.add(key);
  sourceMetrics.push({ label: cleanLabel, value: typeof value === 'number' ? formatNumber(value) : String(value) });
}

if (item.display_metrics?.items) {
  for (const metric of item.display_metrics.items) {
    if (metric.label !== '📖 来源') addMetric(metric.label, metric.value);
  }
}

const lowerSource = sourceName.toLowerCase();
if (lowerSource.includes('github')) {
  addMetric('Stars', rawMetrics.stars ?? rawMetrics.stargazers_count);
  addMetric('Forks', rawMetrics.forks ?? rawMetrics.forks_count);
  addMetric('Issues', rawMetrics.open_issues ?? rawMetrics.open_issues_count ?? rawMetrics.issues);
  addMetric('Language', extra.language ?? rawMetrics.language);
}
if (lowerSource.includes('hackernews') || lowerSource.includes('hacker news')) {
  addMetric('Score', rawMetrics.score);
  addMetric('Comments', rawMetrics.comments);
}
if (lowerSource.includes('twitter') || lowerSource.includes('x')) {
  addMetric('Tweets', rawMetrics.tweet_count);
  addMetric('Likes', rawMetrics.likes);
  addMetric('Reposts', rawMetrics.retweets);
}

const paragraphs = (item.expert_insight || '').split('\n').filter((p: string) => p.trim());
const readmeImages = asStringArray(extra.readme_images);
const mediaUrls = asStringArray(extra.media_urls);
const videoUrl = mediaUrls.find((url) => /\.(mp4|webm|mov)(\?|#|$)/i.test(url));
const mediaImageUrl = mediaUrls.find((url) => /\.(png|jpg|jpeg|webp|gif)(\?|#|$)/i.test(url));
const previewImageUrl = mediaImageUrl || extra.thumbnail_url || readmeImages[0];

const sentimentLabel: Record<string, string> = { positive: '正面', mixed: '意见分歧', negative: '负面' };
const sentimentClass: Record<string, string> = { positive: 'positive', mixed: 'mixed', negative: 'negative' };
const maturityLabel: Record<string, string> = { production: 'Production', beta: 'Beta', experimental: 'Experimental' };
const maturityClass: Record<string, string> = { production: 'production', beta: 'beta', experimental: 'experimental' };
---

<BaseLayout
  title={`${titleText} | ${dateText} 日报快照 | AmazingIndex`}
  description={metaDescription}
  canonicalUrl={articleUrl}
  ogType="article"
  ogTitle={titleText}
  ogDescription={metaDescription}
  ogUrl={articleUrl}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": titleText,
    "description": metaDescription,
    "url": articleUrl,
    "datePublished": item.created_at || item.snapshot_date,
    "isPartOf": {
      "@type": "CreativeWork",
      "name": `${dateText} AI 日报`,
      "url": dailyUrl,
    },
    "publisher": { "@type": "Organization", "name": "AmazingIndex" }
  }}
>
  <Masthead items={items} />
  <NavBar categories={categories} selectedCategory={item.category || '全部'} date={date} />

  <main class="snapshot-page">
    <div class="snapshot-shell">
      <article class="snapshot-main">
        <header class="snapshot-header">
          <div class="snapshot-prelude">
            <a href={backUrl} class="snapshot-back">← 返回 {dateText} 日报</a>
            <div class="snapshot-kicker">日报快照 · Daily Snapshot</div>
            <div class="snapshot-rank-line">
              <span>NO. {rankText}</span>
              <i></i>
            </div>
          </div>
          <h1 class="snapshot-title">{titleText}</h1>
          <div class="snapshot-meta">
            <span>{contentTypeLabel}</span>
            <span>{sourceName}</span>
            <span>{dateText}</span>
          </div>
        </header>

        <div class="snapshot-mobile-info" aria-label="推荐指数与来源指标">
          <div class="snapshot-mobile-score">
            <span>推荐指数</span>
            <strong>{ahaScore}</strong>
            <em>NO. {rankText} · {dateText}</em>
          </div>
          {sourceMetrics.length > 0 && (
            <div class="snapshot-mobile-metrics">
              {sourceMetrics.slice(0, 4).map((metric) => (
                <span><b>{metric.label}</b>{metric.value}</span>
              ))}
            </div>
          )}
        </div>

        {summaryText && (
          <section class="snapshot-summary">
            <div class="snapshot-section-label">为什么值得看</div>
            <p>{summaryText}</p>
          </section>
        )}

        {extra.description && (
          <p class="snapshot-description-en">{extra.description}</p>
        )}

        {(videoUrl || previewImageUrl) && (
          <section class="snapshot-media">
            <div class="snapshot-section-label">媒体预览</div>
            {videoUrl ? (
              <video
                src={videoUrl}
                poster={extra.thumbnail_url || previewImageUrl || undefined}
                controls
                muted
                playsinline
                preload="metadata"
              />
            ) : (
              <img
                src={previewImageUrl}
                alt={titleText}
                loading="lazy"
                width="800"
                height="450"
                onerror="this.parentElement.style.display='none'"
              />
            )}
          </section>
        )}

        <section class="snapshot-editor-note">
          <div class="snapshot-section-label">编辑判断</div>
          <div class="snapshot-editor-body">
            {paragraphs.length > 0
              ? paragraphs.map((p: string) => <p>{p}</p>)
              : <p>暂无专家洞察</p>
            }
          </div>
        </section>

        {item.content_type === 'repo' && extra.star_history_url && (
          <section class="snapshot-media">
            <div class="snapshot-section-label">Star History</div>
            <img
              src={extra.star_history_url}
              alt="Star History"
              loading="lazy"
              width="800"
              height="400"
              onerror="this.parentElement.style.display='none'"
            />
          </section>
        )}

        {enrichment.sentiment && (
          <section class="snapshot-enrichment">
            <div class="snapshot-section-label">社区反馈</div>
            <div class="enrichment-badges">
              <span class={`enrichment-badge ${sentimentClass[enrichment.sentiment] || ''}`}>
                {sentimentLabel[enrichment.sentiment] || enrichment.sentiment}
              </span>
              {enrichment.comment_count && (
                <span class="enrichment-badge neutral">{enrichment.comment_count} 条评论</span>
              )}
            </div>
            {enrichment.core_debate && <p class="enrichment-text">核心争论：{enrichment.core_debate}</p>}
            {enrichment.top_comments_raw?.length > 0 && (
              <div class="enrichment-comments">
                {enrichment.top_comments_raw.map((comment: any) => (
                  <div class="enrichment-comment">
                    <div class="enrichment-comment-header">
                      <span class="enrichment-comment-author">{comment.author}</span>
                      {comment.points > 0 && <span class="enrichment-comment-points">▲ {comment.points}</span>}
                    </div>
                    <p class="enrichment-comment-text">{comment.text}</p>
                  </div>
                ))}
              </div>
            )}
            {enrichment.alternatives?.length > 0 && (
              <div class="enrichment-tags">
                <span class="enrichment-tag-label">替代方案：</span>
                {enrichment.alternatives.map((alt: string) => <span class="enrichment-tag">{alt}</span>)}
              </div>
            )}
          </section>
        )}

        {enrichment.maturity && (
          <section class="snapshot-enrichment">
            <div class="snapshot-section-label">生态分析</div>
            <div class="enrichment-badges">
              <span class={`enrichment-badge ${maturityClass[enrichment.maturity] || ''}`}>
                {maturityLabel[enrichment.maturity] || enrichment.maturity}
              </span>
            </div>
            {enrichment.ecosystem_position && <p class="enrichment-text">{enrichment.ecosystem_position}</p>}
            {enrichment.unique_value && <p class="enrichment-text">独特价值：{enrichment.unique_value}</p>}
            {enrichment.competitors?.length > 0 && (
              <div class="enrichment-competitors">
                <div class="enrichment-tag-label">竞品：</div>
                {enrichment.competitors.map((competitor: any) => (
                  <div class="enrichment-competitor">
                    <a href={`https://github.com/${competitor.name}`} target="_blank" rel="noopener noreferrer" class="enrichment-competitor-name">
                      {competitor.name}
                    </a>
                    {competitor.stars > 0 && <span class="enrichment-competitor-stars">★ {formatNumber(competitor.stars)}</span>}
                    {competitor.comparison && <span class="enrichment-competitor-desc">{competitor.comparison}</span>}
                  </div>
                ))}
              </div>
            )}
          </section>
        )}

        {enrichment.related_articles?.length > 0 && (
          <section class="snapshot-enrichment">
            <div class="snapshot-section-label">相关内容</div>
            <div class="enrichment-articles">
              {enrichment.related_articles.map((article: any) => (
                <a href={article.url} target="_blank" rel="noopener noreferrer" class="enrichment-article">
                  <span class="enrichment-article-title">{article.title}</span>
                  {article.snippet && <span class="enrichment-article-snippet">{article.snippet}</span>}
                </a>
              ))}
            </div>
            {enrichment.key_discussions?.length > 0 && (
              <div class="enrichment-discussions">
                <div class="enrichment-tag-label">社区讨论：</div>
                {enrichment.key_discussions.map((discussion: any) => (
                  <a href={discussion.url} target="_blank" rel="noopener noreferrer" class="enrichment-discussion">
                    <span class="enrichment-discussion-source">{discussion.source}</span>
                    <span class="enrichment-discussion-summary">{discussion.summary}</span>
                  </a>
                ))}
              </div>
            )}
          </section>
        )}

        {item.content_type === 'tweet_digest' && tweets.length > 0 && (
          <section class="snapshot-enrichment">
            <div class="snapshot-section-label">推文合集 · {tweets.length} 条</div>
            <div class="enrichment-tweets">
              {tweets.map((tweet: any) => (
                <div class="enrichment-tweet">
                  <div class="enrichment-tweet-header">
                    <span class="enrichment-tweet-author">@{tweet.author}</span>
                    <span class="enrichment-tweet-stats">
                      {tweet.likes > 0 && <span>Likes {formatNumber(tweet.likes)}</span>}
                      {tweet.retweets > 0 && <span>Reposts {formatNumber(tweet.retweets)}</span>}
                    </span>
                  </div>
                  <p class="enrichment-tweet-text">{tweet.text}</p>
                  {tweet.url && (
                    <a href={tweet.url} target="_blank" rel="noopener noreferrer" class="enrichment-tweet-link">查看原文 →</a>
                  )}
                </div>
              ))}
            </div>
          </section>
        )}

        <nav class="snapshot-same-day" aria-label="同日精选导航">
          <div class="snapshot-section-label">同日精选</div>
          <div class="snapshot-day-nav">
            {prevItem ? (
              <a href={articleUrlFor(prevItem)} class="snapshot-day-link">
                <span>上一篇</span>
                <strong>NO. {String(prevItem.rank || 0).padStart(3, '0')}</strong>
                <em>{articleTitleFor(prevItem)}</em>
              </a>
            ) : (
              <span class="snapshot-day-link disabled">
                <span>上一篇</span>
                <em>已经是当日第一条</em>
              </span>
            )}
            {nextItem ? (
              <a href={articleUrlFor(nextItem)} class="snapshot-day-link">
                <span>下一篇</span>
                <strong>NO. {String(nextItem.rank || 0).padStart(3, '0')}</strong>
                <em>{articleTitleFor(nextItem)}</em>
              </a>
            ) : (
              <span class="snapshot-day-link disabled">
                <span>下一篇</span>
                <em>已经是当日最后一条</em>
              </span>
            )}
          </div>
          <a href={backUrl} class="snapshot-return-link">返回 {dateText} 日报 →</a>
        </nav>

        {originalUrl && (
          <a
            href={originalUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="snapshot-original-btn mobile"
            data-item-id={item.processed_item_id}
            data-snapshot-date={item.snapshot_date}
            data-event="click_original"
          >
            查看原文 →
          </a>
        )}
      </article>

      <aside class="snapshot-sidebar" aria-label="推荐指数与来源指标">
        <div class="snapshot-score-card">
          <div class="score-header">推荐指数 / WORTH READING</div>
          <div class="score-display">
            <span class="score-number">{ahaScore}</span>
            <div class="score-unit">综合评分 · 满分 100</div>
          </div>
          <div class="score-chart" aria-hidden="true">
            <div class="bar" style="height: 62%"></div>
            <div class="bar" style="height: 72%"></div>
            <div class="bar" style="height: 58%"></div>
            <div class="bar" style="height: 66%"></div>
            <div class="bar" style="height: 74%"></div>
            <div class="bar" style="height: 60%"></div>
            <div class="bar today" style="height: 82%"></div>
          </div>
        </div>

        {sourceMetrics.length > 0 && (
          <div class="snapshot-side-section">
            <div class="snapshot-sidebar-label">来源指标</div>
            <dl class="snapshot-facts">
              {sourceMetrics.map((metric) => (
                <div>
                  <dt>{metric.label}</dt>
                  <dd>{metric.value}</dd>
                </div>
              ))}
            </dl>
          </div>
        )}

        <p class="snapshot-freeze-note">以上数据为 {dateText} 当日快照，不代表实时指标。</p>

        {originalUrl && (
          <a
            href={originalUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="snapshot-original-btn"
            data-item-id={item.processed_item_id}
            data-snapshot-date={item.snapshot_date}
            data-event="click_original"
          >
            查看原文 →
          </a>
        )}
      </aside>
    </div>
  </main>

  <Footer showArchiveBanner={true} date={date} />
</BaseLayout>
